<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>J Plus Booksmart - POS</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Dexie.js CDN for Database -->
    <script src="https://unpkg.com/dexie/dist/dexie.js"></script>
    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Chart.js CDN -->
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="style.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 h-screen flex overflow-hidden text-gray-800">
    <!-- Sidebar -->
    <aside class="w-64 bg-[#4f46e5] text-white flex flex-col hidden sm:flex shadow-2xl z-20">
        <div class="p-6 text-center border-b border-indigo-500/30">
            <div class="flex items-center justify-center gap-2">
                <i data-lucide="book-open" class="text-white w-8 h-8"></i>
                <h1 class="text-2xl font-bold text-white tracking-wide">Airnow</h1>
            </div>
            <p class="text-xs text-indigo-200 mt-1 font-medium tracking-wider uppercase">Booksmart POS</p>
        </div>
        <nav class="flex-1 px-4 py-8 space-y-1 overflow-y-auto mt-2">
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-white text-indigo-700 font-semibold shadow-sm transition-all"
                data-tab="pos">
                <i data-lucide="shopping-cart" class="w-5 h-5"></i> POS Terminal
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="dashboard">
                <i data-lucide="layout-dashboard" class="w-5 h-5"></i> Dashboard
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="inventory">
                <i data-lucide="package" class="w-5 h-5"></i> Inventory
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="credits">
                <i data-lucide="users" class="w-5 h-5"></i> Credits
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="utilities">
                <i data-lucide="file-text" class="w-5 h-5"></i> Utility Bills
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="expenses">
                <i data-lucide="receipt" class="w-5 h-5"></i> Expenses
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="suppliers">
                <i data-lucide="truck" class="w-5 h-5"></i> Suppliers
            </button>
            <button
                class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-indigo-100 font-medium transition-all"
                data-tab="printjobs">
                <i data-lucide="printer" class="w-5 h-5"></i> Print Jobs
            </button>
        </nav>
        <div class="p-4 bg-indigo-800/50 mt-auto m-4 rounded-xl text-center text-xs text-indigo-200 shadow-inner">
            F2: Search | F9: Print | Esc: Clear
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <!-- Top Bar for mobile -->
        <header class="bg-white shadow px-6 py-4 flex justify-between items-center sm:hidden">
            <h1 class="text-xl font-bold text-gray-800">J Plus POS</h1>
            <button id="mobile-menu-btn" class="text-gray-600"><i data-lucide="menu"></i></button>
        </header>

        <!-- Container for Tabs -->
        <div id="tab-content" class="flex-1 overflow-y-auto w-full">

            <!-- ====== Dashboard Tab ====== -->
            <section id="tab-dashboard" class="tab-pane hidden p-8 max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-3xl font-bold text-gray-800">Balance overview</h2>
                    <div class="flex items-center gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 shadow-sm relative">
                            <i data-lucide="bell" class="w-5 h-5"></i>
                            <span
                                class="absolute top-0 right-0 w-3 h-3 bg-red-500 border-2 border-white rounded-full"></span>
                        </div>
                        <div
                            class="w-10 h-10 rounded-full overflow-hidden border-2 border-white shadow-sm bg-indigo-200 flex items-center justify-center">
                            <i data-lucide="user" class="text-indigo-500"></i>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
                    <!-- Cards -->
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-5 hover:shadow-md transition-shadow">
                        <div class="w-14 h-14 rounded-full bg-cyan-50 flex items-center justify-center text-cyan-500">
                            <i data-lucide="trending-up" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm font-medium mb-1">Today's Sales</p>
                            <p class="text-2xl font-bold text-slate-800" id="dash-today-sales">Rs. 0</p>
                        </div>
                    </div>
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-5 hover:shadow-md transition-shadow">
                        <div
                            class="w-14 h-14 rounded-full bg-purple-50 flex items-center justify-center text-purple-500">
                            <i data-lucide="receipt" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm font-medium mb-1">Today's Exp.</p>
                            <p class="text-2xl font-bold text-slate-800" id="dash-expenses">Rs. 0</p>
                        </div>
                    </div>
                    <div
                        class="bg-gradient-to-br from-indigo-500 to-purple-600 p-6 rounded-2xl shadow-md text-white flex items-center gap-5 relative overflow-hidden">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
                        <div
                            class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center backdrop-blur-sm">
                            <i data-lucide="pie-chart" class="w-6 h-6"></i>
                        </div>
                        <div class="relative z-10">
                            <p class="text-indigo-100 text-sm font-medium mb-1">Net Profit</p>
                            <p class="text-2xl font-black text-white" id="dash-net-profit">Rs. 0</p>
                        </div>
                    </div>
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-center gap-3">
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-slate-400 font-medium flex items-center gap-1"><i
                                    data-lucide="arrow-down-right" class="w-4 h-4 text-cyan-500"></i> IN</span>
                            <span class="font-bold text-slate-800" id="dash-cash-in">Rs. 0</span>
                        </div>
                        <div class="h-px w-full bg-slate-100"></div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-slate-400 font-medium flex items-center gap-1"><i
                                    data-lucide="arrow-up-right" class="w-4 h-4 text-red-400"></i> OUT</span>
                            <span class="font-bold text-slate-800" id="dash-cash-out">Rs. 0</span>
                        </div>
                    </div>
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-5 hover:shadow-md transition-shadow border-b-4 border-b-indigo-500">
                        <div
                            class="w-14 h-14 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-500">
                            <i data-lucide="wallet" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm font-medium mb-1">Drawer Cash</p>
                            <p class="text-2xl font-black text-indigo-600" id="dash-drawer-cash">Rs. 0</p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div
                        class="bg-white rounded-3xl shadow-sm border border-slate-100 p-8 flex flex-col justify-center relative overflow-hidden group">
                        <div
                            class="absolute -right-10 -bottom-10 w-40 h-40 bg-indigo-50 rounded-full opacity-50 group-hover:scale-110 transition-transform duration-500">
                        </div>
                        <div class="flex justify-between items-center mb-6 relative z-10">
                            <h3 class="text-xl font-bold text-slate-800">Payment methods</h3>
                        </div>
                        <div class="flex gap-4 relative z-10">
                            <button id="btn-modal-cash-in"
                                class="flex-1 py-5 bg-white shadow-md text-slate-700 border border-slate-100 rounded-2xl font-semibold hover:shadow-lg hover:-translate-y-1 transition-all flex flex-col items-center justify-center gap-3">
                                <div
                                    class="w-12 h-12 rounded-full bg-cyan-50 text-cyan-500 flex items-center justify-center mb-1">
                                    <i data-lucide="plus-circle" class="w-6 h-6"></i>
                                </div>
                                Record IN
                            </button>
                            <button id="btn-modal-cash-out"
                                class="flex-1 py-5 bg-white shadow-md text-slate-700 border border-slate-100 rounded-2xl font-semibold hover:shadow-lg hover:-translate-y-1 transition-all flex flex-col items-center justify-center gap-3">
                                <div
                                    class="w-12 h-12 rounded-full bg-red-50 text-red-500 flex items-center justify-center mb-1">
                                    <i data-lucide="minus-circle" class="w-6 h-6"></i>
                                </div>
                                Record OUT
                            </button>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                        <h3 class="text-lg font-bold mb-4">Cash Log (Today)</h3>
                        <div class="overflow-y-auto max-h-48 space-y-2 pr-2" id="dash-logs">
                            <!-- Populated via JS -->
                            <p class="text-gray-500 text-sm text-center py-4">No cash logs for today.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ====== POS Tab ====== -->
            <section id="tab-pos" class="tab-pane active h-full flex flex-col md:flex-row p-4 gap-4">
                <!-- Left: Product Selection -->
                <div
                    class="flex-1 bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col h-full overflow-hidden relative">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-3xl font-bold text-slate-800 tracking-tight">Terminal</h2>
                        <div class="flex bg-slate-100/80 backdrop-blur-sm rounded-xl p-1 shadow-inner">
                            <button id="btn-bookshop"
                                class="px-5 py-2 bg-white rounded-lg shadow-sm text-indigo-700 text-sm font-semibold transition-all cursor-pointer">Bookshop</button>
                            <button id="btn-services"
                                class="px-5 py-2 text-slate-500 hover:text-indigo-600 rounded-lg text-sm font-medium transition-colors cursor-pointer">Printing
                                Services</button>
                        </div>
                    </div>

                    <!-- Search Bar -->
                    <div class="relative mb-6">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i data-lucide="search" class="text-indigo-400 w-5 h-5"></i>
                        </div>
                        <input type="text" id="pos-search"
                            class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 text-lg transition-all shadow-sm"
                            placeholder="Scan Barcode or Search (F2)">
                    </div>

                    <!-- Products Grid -->
                    <div id="pos-products-grid"
                        class="flex-1 overflow-y-auto grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 pb-20">
                        <!-- Populated dynamically -->
                    </div>

                    <!-- Services Form (Hidden by default) -->
                    <div id="pos-services-form" class="hidden flex-1 flex flex-col gap-4">
                        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                            <h3 class="text-lg font-semibold mb-4">Add Custom Service</h3>
                            <div class="space-y-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Service
                                        Description</label>
                                    <input type="text" id="service-desc"
                                        class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                                        placeholder="e.g., A4 Color Printout x 10">
                                </div>
                                <div class="flex gap-4">
                                    <div class="flex-1">
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                                        <input type="number" id="service-qty"
                                            class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                                            value="1" min="1">
                                    </div>
                                    <div class="flex-1">
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Unit Price</label>
                                        <input type="number" id="service-price"
                                            class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                                            placeholder="0.00" min="0" step="0.01">
                                    </div>
                                </div>
                                <div class="bg-gray-50 border border-gray-200 rounded p-3 mb-2 flex items-center gap-3">
                                    <span class="text-sm font-bold text-gray-700 w-24">Calculator:</span>
                                    <input type="number" id="calc-pages" placeholder="Pages"
                                        class="w-20 p-2 text-sm border rounded">
                                    <span class="text-gray-500 text-sm">x</span>
                                    <input type="number" id="calc-price" placeholder="Rate"
                                        class="w-16 p-2 text-sm border rounded">
                                    <span class="text-gray-500 text-sm">+</span>
                                    <input type="number" id="calc-bind" placeholder="Binding"
                                        class="w-20 p-2 text-sm border rounded" value="0">
                                    <button type="button" id="btn-calc-apply"
                                        class="ml-auto px-3 py-2 bg-gray-200 hover:bg-gray-300 rounded text-sm font-bold text-gray-700">Apply</button>
                                </div>
                                <button id="btn-add-service"
                                    class="w-full py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition">Add
                                    to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Cart & Checkout -->
                <div
                    class="w-full md:w-[400px] bg-white rounded-3xl shadow-sm border border-slate-100 flex flex-col h-[50vh] md:h-full overflow-hidden relative">
                    <div class="p-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center z-10">
                        <h3 class="font-bold text-lg text-slate-800">Current Sale</h3>
                        <button id="btn-clear-cart"
                            class="text-red-400 hover:text-red-600 hover:bg-red-50 px-3 py-1.5 rounded-lg text-sm font-medium flex items-center gap-1.5 transition-colors"><i
                                data-lucide="trash-2" class="w-4 h-4"></i> Clear (Esc)</button>
                    </div>

                    <div class="flex-1 overflow-y-auto p-4 space-y-3 bg-slate-50/30" id="cart-items">
                        <!-- Populated dynamically -->
                        <div class="text-center text-slate-400 mt-12 flex flex-col items-center justify-center">
                            <div
                                class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mb-3 text-slate-300">
                                <i data-lucide="shopping-bag" class="w-8 h-8"></i>
                            </div>
                            <p class="font-medium">Cart is empty</p>
                            <p class="text-xs mt-1 text-slate-400">Scan an item to start</p>
                        </div>
                    </div>

                    <div
                        class="p-5 border-t border-slate-100 bg-white space-y-4 z-10 shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.05)]">
                        <div class="flex justify-between text-slate-500 font-medium">
                            <span>Subtotal</span>
                            <span id="cart-subtotal">Rs. 0.00</span>
                        </div>
                        <div class="flex justify-between text-slate-500 font-medium items-center">
                            <span>Discount</span>
                            <div
                                class="flex items-center bg-slate-50 rounded-lg p-1 border border-slate-200 focus-within:border-indigo-500 focus-within:ring-2 focus-within:ring-indigo-100 transition-all">
                                <span class="ml-2 mr-1 text-sm text-slate-400 font-bold">Rs.</span>
                                <input type="number" id="cart-discount"
                                    class="w-20 text-right bg-transparent border-none focus:ring-0 px-2 py-1 text-slate-700 font-bold"
                                    placeholder="0" value="0" min="0" step="0.01">
                            </div>
                        </div>
                        <div
                            class="flex justify-between font-black text-2xl text-slate-800 pt-3 border-t border-slate-100 items-end">
                            <span class="text-base font-bold text-slate-400 mb-1">Total</span>
                            <span id="cart-total" class="text-indigo-600">Rs. 0.00</span>
                        </div>

                        <!-- Payment Types & Hold Bill -->
                        <div class="grid grid-cols-2 gap-3 pt-2">
                            <button id="btn-pay-cash"
                                class="py-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl font-bold shadow-md shadow-indigo-200 transition-all hover:-translate-y-0.5 whitespace-nowrap text-sm flex items-center justify-center gap-2">
                                <i data-lucide="banknote" class="w-4 h-4 opacity-80"></i> Cash (Enter)
                            </button>
                            <button id="btn-pay-credit"
                                class="py-4 bg-white text-indigo-600 border border-indigo-200 hover:bg-indigo-50 hover:border-indigo-300 rounded-2xl font-bold transition-all whitespace-nowrap text-sm flex items-center justify-center gap-2">
                                <i data-lucide="book" class="w-4 h-4 opacity-80"></i> Credit
                            </button>
                            <button id="btn-hold-bill"
                                class="py-3 bg-slate-50 border border-slate-200 hover:bg-slate-100 text-slate-600 rounded-2xl font-semibold text-xs transition-all flex items-center justify-center gap-1.5">
                                <i data-lucide="pause-circle" class="w-4 h-4"></i> Hold Bill
                            </button>
                            <button id="btn-show-held"
                                class="py-3 bg-slate-50 border border-slate-200 hover:bg-slate-100 text-slate-600 rounded-2xl font-semibold text-xs transition-all flex items-center justify-center gap-1.5">
                                <i data-lucide="library" class="w-4 h-4"></i> Stored Bills
                                <span id="held-count"
                                    class="bg-indigo-600 text-white rounded-full px-2 py-0.5 text-[10px] font-bold">0</span>
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ====== Inventory Tab ====== -->
            <section id="tab-inventory" class="tab-pane hidden p-8 max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-3xl font-bold text-slate-800">Inventory Management</h2>
                    <button id="btn-add-product"
                        class="px-6 py-3 bg-indigo-600 text-white rounded-xl shadow-md shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-0.5 flex items-center gap-2 font-semibold transition-all">
                        <i data-lucide="plus" class="w-5 h-5"></i> Add Product
                    </button>
                </div>

                <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                    <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-white relative z-10">
                        <div class="relative w-full max-w-md">
                            <i data-lucide="search" class="w-5 h-5 absolute left-4 top-3.5 text-slate-400"></i>
                            <input type="text" id="inventory-search"
                                class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all font-medium"
                                placeholder="Search products by name or barcode...">
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[800px]">
                            <thead>
                                <tr
                                    class="bg-slate-50/50 text-slate-500 text-sm font-semibold uppercase tracking-wider">
                                    <th class="p-4 pl-6 border-b border-slate-100">Barcode</th>
                                    <th class="p-4 border-b border-slate-100">Name</th>
                                    <th class="p-4 border-b border-slate-100">Category</th>
                                    <th class="p-4 border-b border-slate-100 text-right">Price</th>
                                    <th class="p-4 border-b border-slate-100 text-right">Stock</th>
                                    <th class="p-4 pr-6 border-b border-slate-100 text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="inventory-table-body"
                                class="text-slate-700 font-medium divide-y divide-slate-50">
                                <!-- Populated dynamically -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- ====== Credits Tab ====== -->
            <section id="tab-credits" class="tab-pane hidden p-8 max-w-7xl mx-auto">
                <h2 class="text-3xl font-bold text-slate-800 mb-8">Credit Management</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-8 flex flex-col h-full">
                        <div class="flex items-center gap-3 mb-6">
                            <div
                                class="w-10 h-10 rounded-full bg-orange-50 text-orange-500 flex items-center justify-center">
                                <i data-lucide="users" class="w-5 h-5"></i>
                            </div>
                            <h3 class="text-xl font-bold text-slate-800">Active Debts</h3>
                        </div>
                        <div class="overflow-y-auto max-h-[500px] flex-1 pr-2 space-y-3" id="credits-list">
                            <!-- Populated dynamically -->
                        </div>
                    </div>
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-8 flex flex-col relative overflow-hidden group"
                        id="credit-payment-panel">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-orange-400 to-amber-500">
                        </div>
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Record Payment</h3>
                        <p class="text-slate-500 text-sm mb-6">Select a customer from the active debts list to record a
                            payment.</p>

                        <form id="credit-payment-form" class="space-y-5 hidden relative z-10 flex-1 flex flex-col">
                            <input type="hidden" id="credit-payment-id">
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Customer Name</label>
                                <input type="text" id="credit-payment-name"
                                    class="w-full p-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-600 font-medium focus:outline-none"
                                    readonly>
                            </div>
                            <div
                                class="flex justify-between items-center bg-orange-50/50 p-4 rounded-xl border border-orange-100">
                                <span class="text-sm font-semibold text-orange-800">Remaining Balance:</span>
                                <span class="font-bold text-orange-600 text-xl" id="credit-current-balance">Rs.
                                    0.00</span>
                            </div>
                            <div class="mt-auto">
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Payment Amount
                                    (Rs.)</label>
                                <input type="number" id="credit-payment-amount"
                                    class="w-full p-4 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/30 focus:border-orange-500 text-lg shadow-sm transition-all font-bold"
                                    min="0.01" step="0.01" placeholder="Enter amount..." required>
                            </div>
                            <button type="submit"
                                class="w-full py-4 bg-gradient-to-r from-orange-500 to-amber-500 text-white rounded-xl font-bold hover:shadow-lg hover:shadow-orange-500/30 hover:-translate-y-0.5 transition-all flex justify-center items-center gap-2 mt-4">
                                <i data-lucide="check-circle" class="w-5 h-5"></i> Record & Print Receipt
                            </button>
                        </form>
                    </div>
                </div>
            </section>

            <!-- ====== Utility Bills Tab ====== -->
            <section id="tab-utilities" class="tab-pane hidden p-8 max-w-7xl mx-auto">
                <h2 class="text-3xl font-bold text-slate-800 mb-8">Utility Bill Payments</h2>
                <div
                    class="max-w-md bg-white rounded-3xl shadow-sm border border-slate-100 p-8 relative overflow-hidden group">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-indigo-500"></div>
                    <form id="utility-form" class="space-y-5 relative z-10">
                        <div>
                            <label class="block text-sm font-semibold text-slate-600 mb-1.5">Bill Type</label>
                            <select id="utility-type"
                                class="w-full p-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 text-slate-700 font-medium transition-all appearance-none cursor-pointer">
                                <option value="Electricity - CEB">Electricity - CEB</option>
                                <option value="Electricity - LECO">Electricity - LECO</option>
                                <option value="Water">Water Board</option>
                                <option value="Telecom / Internet">Telecom / Internet</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-600 mb-1.5">Account Number</label>
                            <input type="text" id="utility-acc"
                                class="w-full p-3.5 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 shadow-sm transition-all"
                                placeholder="Enter account code" required>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-600 mb-1.5">Customer Name /
                                Reference</label>
                            <input type="text" id="utility-name"
                                class="w-full p-3.5 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 shadow-sm transition-all"
                                placeholder="Optional name">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-600 mb-1.5">Amount (Rs.)</label>
                            <input type="number" id="utility-amount"
                                class="w-full p-3.5 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 text-lg shadow-sm transition-all font-bold"
                                min="0.01" step="0.01" placeholder="0.00" required>
                        </div>
                        <button type="submit"
                            class="w-full py-4 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl font-bold hover:shadow-lg hover:shadow-blue-500/30 hover:-translate-y-0.5 transition-all flex justify-center items-center gap-2 mt-2">
                            <i data-lucide="printer" class="w-5 h-5"></i> Record & Print Receipt
                        </button>
                    </form>
                </div>
            </section>
        </div>
    </main>

    <!-- ====== Modals ====== -->

    <!-- Product Modal -->
    <div id="product-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-md m-4">
            <div class="p-4 border-b flex justify-between items-center bg-gray-50 rounded-t-lg">
                <h3 class="font-bold text-lg" id="product-modal-title">Add New Product</h3>
                <button class="text-gray-500 hover:text-gray-700 modal-close-btn transition"><i
                        data-lucide="x"></i></button>
            </div>
            <div class="p-6">
                <form id="product-form" class="space-y-4">
                    <input type="hidden" id="prod-id">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Barcode</label>
                        <input type="text" id="prod-barcode"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                            required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input type="text" id="prod-name"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                            required>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Price (Rs.)</label>
                            <input type="number" id="prod-price"
                                class="w-full p-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                                min="0" step="0.01" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Stock</label>
                            <input type="number" id="prod-stock"
                                class="w-full p-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                                min="0" required>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                        <select id="prod-category"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
                            <option value="Stationery">Stationery</option>
                            <option value="Books">Books</option>
                            <option value="Accessories">Accessories</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="pt-4 flex justify-end gap-2">
                        <button type="button"
                            class="px-4 py-2 text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 modal-close-btn transition">Cancel</button>
                        <button type="submit"
                            class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Save
                            Product</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Credit Customer Modal (For POS Checkout) -->
    <div id="credit-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-md m-4">
            <div class="p-4 border-b flex justify-between items-center bg-gray-50 rounded-t-lg">
                <h3 class="font-bold text-lg">Save Credit Bill</h3>
                <button class="text-gray-500 hover:text-gray-700 transition" id="credit-modal-close"><i
                        data-lucide="x"></i></button>
            </div>
            <div class="p-6">
                <form id="credit-checkout-form" class="space-y-4">
                    <div class="bg-orange-50 p-3 rounded-lg border border-orange-100 flex justify-between items-center">
                        <span class="text-sm font-medium text-orange-800">Total Bill Amount:</span>
                        <span class="font-bold text-orange-600 text-lg" id="credit-checkout-total"></span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Customer Name</label>
                        <input type="text" id="credit-checkout-name"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-orange-500 focus:border-orange-500"
                            required>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Customer Mobile (For
                            WhatsApp)</label>
                        <input type="text" id="credit-checkout-mobile"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-orange-500 focus:border-orange-500"
                            placeholder="07xxxxxxxx">
                        <div class="flex items-center mt-2">
                            <input type="checkbox" id="credit-whatsapp-checkbox"
                                class="w-4 h-4 text-orange-600 border-gray-300 rounded focus:ring-orange-500">
                            <label for="credit-whatsapp-checkbox" class="ml-2 block text-sm text-gray-700">Send WhatsApp
                                Receipt</label>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Advance Payment (Rs.)</label>
                        <input type="number" id="credit-checkout-advance"
                            class="w-full p-3 border border-gray-300 rounded-lg focus:ring-orange-500 focus:border-orange-500"
                            value="0" min="0" step="0.01">
                        <p class="text-xs text-gray-500 mt-1">Leave as 0 if no advance is paid.</p>
                    </div>

                    <div class="pt-4 flex justify-end gap-2">
                        <button type="button"
                            class="px-4 py-2 text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition"
                            id="credit-modal-cancel">Cancel</button>
                        <button type="submit"
                            class="px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition shadow">Save
                            Credit & Print</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Cash Log Modal -->
    <div id="cash-log-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-sm m-4">
            <div class="p-4 border-b flex justify-between items-center bg-gray-50 rounded-t-lg">
                <h3 class="font-bold text-lg" id="cash-modal-title">Cash Flow</h3>
                <button class="text-gray-500 hover:text-gray-700 transition" id="cash-modal-close"><i
                        data-lucide="x"></i></button>
            </div>
            <div class="p-6">
                <form id="cash-log-form" class="space-y-4">
                    <input type="hidden" id="cash-log-type">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Amount (Rs.)</label>
                        <input type="number" id="cash-log-amount"
                            class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 text-lg font-bold"
                            min="0.01" step="0.01" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Reason / Note</label>
                        <input type="text" id="cash-log-reason"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                            required>
                    </div>
                    <div class="pt-4 flex justify-end gap-2">
                        <button type="submit"
                            class="w-full py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-bold transition shadow"
                            id="cash-modal-submit">Save Log</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Cash Checkout Calculator Modal -->
    <div id="cash-checkout-modal"
        class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-sm m-4">
            <div class="p-4 border-b flex justify-between items-center bg-gray-50 rounded-t-lg">
                <h3 class="font-bold text-lg">Cash Payment</h3>
                <button class="text-gray-500 hover:text-gray-700 transition" id="cash-checkout-close"><i
                        data-lucide="x"></i></button>
            </div>
            <div class="p-6">
                <form id="cash-checkout-form" class="space-y-4">
                    <div
                        class="bg-green-50 p-4 rounded-lg border border-green-100 flex justify-between items-center mb-2">
                        <span class="text-sm font-medium text-green-800">Total Bill:</span>
                        <span class="font-bold text-green-700 text-2xl" id="cash-checkout-total"></span>
                    </div>

                    <div class="mb-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Receipt (Optional)</label>
                        <div class="flex items-center gap-2">
                            <input type="text" id="cash-checkout-mobile"
                                class="flex-1 p-2 border border-gray-300 rounded-lg focus:ring-green-500 focus:border-green-500"
                                placeholder="07xxxxxxxx">
                            <div class="flex items-center gap-1 shrink-0">
                                <input type="checkbox" id="cash-whatsapp-checkbox"
                                    class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500">
                                <label for="cash-whatsapp-checkbox" class="text-xs text-gray-700">Send WA</label>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Customer Gave (Rs.)</label>
                        <input type="number" id="cash-checkout-given"
                            class="w-full p-3 border border-gray-400 rounded-lg focus:ring-green-500 focus:border-green-500 text-xl font-bold"
                            min="0" step="0.01" required>
                    </div>

                    <div class="flex justify-between items-center pt-2 pb-2">
                        <span class="text-sm font-bold text-gray-600">Balance / Change:</span>
                        <span class="font-bold text-red-500 text-2xl" id="cash-checkout-change">Rs. 0.00</span>
                    </div>

                    <div class="pt-4 flex flex-col gap-2 border-t border-gray-100">
                        <button type="submit"
                            class="w-full py-3 bg-green-600 text-white rounded-lg font-bold text-lg hover:bg-green-700 transition shadow flex justify-center items-center gap-2"><i
                                data-lucide="printer" class="w-5 h-5"></i> Print & Complete</button>
                        <button type="button"
                            class="w-full py-2 text-gray-600 bg-gray-100 rounded-lg font-medium hover:bg-gray-200 transition"
                            id="cash-checkout-cancel">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Print Job Form Modal -->
    <div id="job-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-sm m-4">
            <div class="p-4 border-b flex justify-between items-center bg-gray-50 rounded-t-lg">
                <h3 class="font-bold text-lg" id="job-modal-title">New Print Job</h3>
                <button class="text-gray-500 hover:text-gray-700 transition modal-close-btn"><i
                        data-lucide="x"></i></button>
            </div>
            <div class="p-6">
                <form id="job-form" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Customer Name</label>
                        <input type="text" id="job-name"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-purple-500 focus:border-purple-500"
                            required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Customer WhatsApp</label>
                        <input type="text" id="job-mobile"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-purple-500 focus:border-purple-500"
                            placeholder="07xxxxxxxx" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Job Description</label>
                        <textarea id="job-desc" rows="3"
                            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-purple-500 focus:border-purple-500"
                            placeholder="e.g. Bind 3 copies of thesis..." required></textarea>
                    </div>
                    <div class="pt-4 flex justify-end gap-2">
                        <button type="button"
                            class="px-4 py-2 text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition modal-close-btn">Cancel</button>
                        <button type="submit"
                            class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition shadow">Save
                            Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ====== Expenses Tab ====== -->
    <section id="tab-expenses" class="tab-pane hidden p-8 max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-800 mb-8">Expense Tracker</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Add Expense -->
            <div
                class="md:col-span-1 bg-white rounded-3xl shadow-sm border border-slate-100 p-8 relative overflow-hidden group h-fit">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-rose-400 to-red-500"></div>
                <h3 class="text-xl font-bold text-slate-800 mb-6 relative z-10 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-rose-50 flex items-center justify-center text-rose-500">
                        <i data-lucide="minus-circle" class="w-4 h-4"></i>
                    </div>
                    Record Expense
                </h3>
                <form id="expense-form" class="space-y-5 relative z-10">
                    <div>
                        <label class="block text-sm font-semibold text-slate-600 mb-1.5">Category</label>
                        <select id="expense-category"
                            class="w-full p-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-rose-500/30 focus:border-rose-500 text-slate-700 font-medium transition-all appearance-none cursor-pointer">
                            <option value="Shop Rent">Shop Rent</option>
                            <option value="Salaries">Salaries</option>
                            <option value="Inventory Purchases">Inventory Purchases</option>
                            <option value="Utility Bills">Utility Bills</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-600 mb-1.5">Description</label>
                        <input type="text" id="expense-desc"
                            class="w-full p-3.5 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-rose-500/30 focus:border-rose-500 shadow-sm transition-all"
                            placeholder="e.g. Bought printer ink" required>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-600 mb-1.5">Amount (Rs.)</label>
                        <input type="number" id="expense-amount"
                            class="w-full p-3.5 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-rose-500/30 focus:border-rose-500 text-lg shadow-sm transition-all font-bold"
                            min="0.01" step="0.01" placeholder="0.00" required>
                    </div>
                    <button type="submit"
                        class="w-full py-4 bg-gradient-to-r from-rose-500 to-red-500 text-white rounded-xl font-bold hover:shadow-lg hover:shadow-rose-500/30 hover:-translate-y-0.5 transition-all mt-2">
                        Save Expense
                    </button>
                </form>
            </div>
            <!-- Expense List -->
            <div
                class="md:col-span-2 bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden flex flex-col">
                <div class="overflow-y-auto max-h-[600px] flex-1">
                    <table class="w-full text-left border-collapse">
                        <thead
                            class="sticky top-0 bg-slate-50/80 backdrop-blur-md z-10 shadow-sm border-b border-slate-100">
                            <tr class="text-slate-500 text-sm font-semibold uppercase tracking-wider">
                                <th class="p-4 pl-6">Date</th>
                                <th class="p-4">Category</th>
                                <th class="p-4">Description</th>
                                <th class="p-4 pr-6 text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="expenses-table-body" class="text-slate-700 font-medium divide-y divide-slate-50">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== Print Jobs Tab ====== -->
    <section id="tab-printjobs" class="tab-pane hidden p-8 max-w-7xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-3xl font-bold text-slate-800">Printing Job Queue</h2>
            <button id="btn-add-job"
                class="px-6 py-3 bg-purple-600 text-white rounded-xl shadow-md shadow-purple-200 hover:bg-purple-700 hover:-translate-y-0.5 flex items-center gap-2 font-semibold transition-all">
                <i data-lucide="plus" class="w-5 h-5"></i> New Job
            </button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
            <!-- Pending -->
            <div
                class="bg-amber-50/50 p-6 rounded-3xl border border-amber-100 min-h-[600px] flex flex-col shadow-inner shadow-amber-500/5">
                <div
                    class="flex items-center gap-3 mb-6 bg-white/60 p-3 rounded-2xl backdrop-blur-sm border border-amber-200/50">
                    <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center">
                        <i data-lucide="clock" class="w-5 h-5"></i>
                    </div>
                    <h3 class="font-bold text-amber-900 text-lg">Pending Queue <span
                            class="bg-amber-200 text-amber-800 px-2.5 py-0.5 rounded-full text-sm ml-2"
                            id="jobs-pending-count">0</span></h3>
                </div>
                <div class="space-y-4 flex-1 overflow-y-auto pr-2" id="jobs-pending-list"></div>
            </div>
            <!-- Completed -->
            <div
                class="bg-emerald-50/50 p-6 rounded-3xl border border-emerald-100 min-h-[600px] flex flex-col shadow-inner shadow-emerald-500/5">
                <div
                    class="flex items-center gap-3 mb-6 bg-white/60 p-3 rounded-2xl backdrop-blur-sm border border-emerald-200/50">
                    <div
                        class="w-10 h-10 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center">
                        <i data-lucide="check-circle-2" class="w-5 h-5"></i>
                    </div>
                    <h3 class="font-bold text-emerald-900 text-lg">Completed <span
                            class="bg-emerald-200 text-emerald-800 px-2.5 py-0.5 rounded-full text-sm ml-2"
                            id="jobs-done-count">0</span></h3>
                </div>
                <div class="space-y-4 flex-1 overflow-y-auto pr-2" id="jobs-done-list"></div>
            </div>
        </div>
    </section>

    <!-- Held Bills Modal -->
    <div id="held-bills-modal"
        class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg m-4 overflow-hidden transform transition-all">
            <div class="p-6 border-b border-slate-100 bg-white flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600">
                        <i data-lucide="library" class="w-5 h-5"></i>
                    </div>
                    <h3 class="font-bold text-xl text-slate-800">Stored Bills</h3>
                </div>
                <button
                    class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full p-2 transition-colors modal-close-btn"><i
                        data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-0">
                <!-- List -->
                <div class="overflow-y-auto max-h-[400px]">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 border-b border-slate-100 sticky top-0">
                            <tr>
                                <th class="p-4 pl-6 text-sm font-semibold text-slate-500">Name / Ref</th>
                                <th class="p-4 text-sm font-semibold text-slate-500 text-right">Total</th>
                                <th class="p-4 pr-6 text-sm font-semibold text-slate-500 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="held-bills-list" class="divide-y divide-slate-50">
                            <!-- Populated dynamically -->
                            <tr>
                                <td colspan="3"
                                    class="text-center p-8 text-slate-400 font-medium flex flex-col items-center justify-center gap-2">
                                    <i data-lucide="inbox" class="w-8 h-8 opacity-50"></i>
                                    No stored bills found
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Hold Bill Name Prompt -->
    <div id="hold-prompt-modal"
        class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm m-4 p-8 transform transition-all">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-500">
                    <i data-lucide="pause-circle" class="w-5 h-5"></i>
                </div>
                <h3 class="font-bold text-xl text-slate-800">Hold Bill</h3>
            </div>
            <p class="text-sm text-slate-500 mb-4">Enter a reference name to store this bill for later.</p>
            <input type="text" id="hold-ref-name"
                class="w-full p-4 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 mb-6 transition-all"
                placeholder="e.g. Kamal - Binding job">
            <div class="flex gap-3">
                <button
                    class="flex-1 bg-slate-100 text-slate-700 rounded-xl py-3 font-bold hover:bg-slate-200 transition-colors modal-close-btn">Cancel</button>
                <button id="btn-confirm-hold"
                    class="flex-1 bg-blue-600 text-white rounded-xl py-3 font-bold hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/30 transition-all hover:-translate-y-0.5">Hold
                    Bill</button>
            </div>
        </div>
    </div>

    <!-- Print Receipt Template (Hidden normally) -->
    <div id="print-area">
        <!-- Filled dynamically -->
    </div>

    <script src="db.js"></script>
    <script src="app.js"></script>
    <script>
        lucide.createIcons();
    </script>
</body>

</html>