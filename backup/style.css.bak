/* Fix print layout for 58mm thermal printers */
#print-area {
    display: none;
}

@media print {

    body>aside,
    body>main {
        display: none !important;
    }

    #print-area {
        display: block !important;
        position: absolute;
        left: 0;
        top: 0;
        width: 58mm;
        /* 58mm paper width */
        margin: 0;
        padding: 0;
        font-family: 'Courier New', Courier, monospace;
        color: #000;
        background: #fff;
    }

    /* Hide scrollbars during print */
    ::-webkit-scrollbar {
        display: none;
    }

    /* Page break handling if necessary */
    @page {
        margin: 0;
    }
}

/* Custom Scrollbar for the app */
::-webkit-scrollbar {
    width: 6px;
    height: 6px;
}

::-webkit-scrollbar-track {
    background: transparent;
}

::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
}

/* Tab visibility */
.tab-pane.hidden {
    display: none !important;
}

/* Item hover styles */
.product-card {
    transition: transform 0.1s, box-shadow 0.1s;
}

.product-card:active {
    transform: scale(0.98);
}